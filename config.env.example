# ============================================================
# config.env.example
# Copia questo file in config.env e inserisci i valori reali.
# config.env NON viene committato (gitignored).
# ============================================================

# Proxmox hypervisor
PROXMOX_SSH="proxmox"       # alias SSH (~/.ssh/config) oppure user@ip
PROXMOX_IP="192.168.x.x"

# narutoPi (Pi-hole + Wazuh agent)
NARUTO_SSH="naruto@192.168.x.x"   # alias SSH o user@ip
NARUTO_IP="192.168.x.x"

# cs42 - SOC Ubuntu (Wazuh SIEM)
CS42_SSH="cs42"             # alias SSH o user@ip
CS42_IP="192.168.x.x"
